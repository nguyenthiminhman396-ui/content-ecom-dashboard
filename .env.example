# ============================================
# Tài khoản đăng nhập app (4 vai trò)
# Copy file này thành `.env` và điền giá trị thực
# ============================================

# Admin
VITE_ACCOUNT_ADMIN_EMAIL=admin@example.com
VITE_ACCOUNT_ADMIN_PASS=
VITE_ACCOUNT_ADMIN_NAME=Admin

# Leader
VITE_ACCOUNT_LEADER_EMAIL=leader@example.com
VITE_ACCOUNT_LEADER_PASS=
VITE_ACCOUNT_LEADER_NAME=Leader

# Member
VITE_ACCOUNT_MEMBER_EMAIL=member@example.com
VITE_ACCOUNT_MEMBER_PASS=
VITE_ACCOUNT_MEMBER_NAME=Member

# Client (không cần mật khẩu)
VITE_ACCOUNT_CLIENT_EMAIL=client@example.com
VITE_ACCOUNT_CLIENT_NAME=Client

# ============================================
# Google Sheets (tùy chọn — dùng làm default values)
# ============================================
VITE_DEFAULT_SPREADSHEET_ID=
VITE_DEFAULT_OAUTH_CLIENT_ID=
